{
  "ConnectionStrings": {
    //"DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Initial Catalog=HealthcarePlatform;Integrated Security=True;"
    "DefaultConnection": "Server=tcp:npdpcdb.database.windows.net,1433;Initial Catalog=HealthcarePlatform;Persist Security Info=False;User ID=dbadmin;Password=Portal1!;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"

  },
  "AzureKeyVault": {
    "VaultUri": "https://your-keyvault.vault.azure.net/"
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "your-tenant-id",
    "ClientId": "your-client-id",
    "Audience": "api://your-api-client-id"
  },
  "AllowedOrigins": {
    "PatientPortal": "https://emr-sage.vercel.app"
  },
  "FHIR": {
    "BaseUrl": "https://your-fhir-server.azurehealthcareapis.com"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/patientservice-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "AllowedHosts": "*"
}

