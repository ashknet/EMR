{
  "buildCommand": "cd PatientPortal && npm run build",
  "outputDirectory": "PatientPortal/dist",
  "installCommand": "cd PatientPortal && npm install --legacy-peer-deps --production=false",
  "framework": "vite",
  "env": {
    "NODE_ENV": "production"
  },
  "build": {
    "env": {
      "NODE_ENV": "production"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
