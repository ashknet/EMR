{
  "buildCommand": "npm run build",
  "outputDirectory": "PatientPortal/dist",
  "installCommand": "npm run install",
  "framework": "vite",
  "env": {
    "NODE_ENV": "production",
    "CI": "true"
  },
  "build": {
    "env": {
      "NODE_ENV": "production",
      "CI": "true"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
