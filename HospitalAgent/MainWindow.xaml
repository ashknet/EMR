<Window x:Class="HospitalAgent.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hospital Agent - Patient Intake" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2563EB" Padding="20,15">
            <StackPanel>
                <TextBlock Text="Hospital Agent - Patient Intake System" 
                           Foreground="White" 
                           FontSize="20" 
                           FontWeight="Bold"/>
                <TextBlock Text="HIPAA-Compliant Data Capture" 
                           Foreground="White" 
                           FontSize="12" 
                           Opacity="0.9"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <TabControl Grid.Row="1" Margin="10">
            <!-- QR Scanner Tab -->
            <TabItem Header="QR Scanner">
                <Grid Margin="20">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Scan Patient QR Code" 
                                   FontSize="18" 
                                   FontWeight="SemiBold" 
                                   Margin="0,0,0,20"
                                   HorizontalAlignment="Center"/>
                        
                        <Border BorderBrush="#DDD" 
                                BorderThickness="2" 
                                Width="400" 
                                Height="400" 
                                Background="#F9FAFB">
                            <TextBlock Text="📷 Camera View" 
                                       FontSize="24" 
                                       Foreground="#999"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>

                        <Button Content="Start Scanning" 
                                Margin="0,20,0,0" 
                                Padding="20,10" 
                                FontSize="14"
                                Background="#2563EB" 
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="ScanQrCode_Click"
                                AutomationProperties.Name="Start QR code scanning"/>
                        
                        <TextBlock Name="ScanResult" 
                                   Text="" 
                                   Margin="0,15,0,0" 
                                   FontSize="12"
                                   Foreground="Green"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Manual Entry Tab -->
            <TabItem Header="Manual Entry">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Patient Information" 
                                   FontSize="18" 
                                   FontWeight="SemiBold" 
                                   Margin="0,0,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="First Name:" Margin="0,0,10,10" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" Padding="8" AutomationProperties.Name="First name"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Last Name:" Margin="0,0,10,10" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" Padding="8" AutomationProperties.Name="Last name"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Date of Birth:" Margin="0,0,10,10" VerticalAlignment="Center"/>
                            <DatePicker Grid.Row="2" Grid.Column="1" Margin="0,0,0,10" AutomationProperties.Name="Date of birth"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Member ID:" Margin="0,0,10,10" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,10" Padding="8" AutomationProperties.Name="Insurance member ID"/>
                        </Grid>

                        <Button Content="Submit" 
                                Margin="0,20,0,0" 
                                Padding="20,10" 
                                Background="#2563EB" 
                                Foreground="White"
                                BorderThickness="0"
                                HorizontalAlignment="Left"
                                Cursor="Hand"
                                AutomationProperties.Name="Submit patient information"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Document Upload Tab -->
            <TabItem Header="Documents">
                <StackPanel Margin="20">
                    <TextBlock Text="Document Upload &amp; OCR" 
                               FontSize="18" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,20"/>

                    <Button Content="📄 Select Document" 
                            Padding="15,10" 
                            Background="#2563EB" 
                            Foreground="White"
                            BorderThickness="0"
                            HorizontalAlignment="Left"
                            Cursor="Hand"
                            Click="SelectDocument_Click"
                            AutomationProperties.Name="Select document to upload"/>

                    <TextBlock Name="SelectedFile" 
                               Text="No file selected" 
                               Margin="0,15,0,0" 
                               FontSize="12"/>

                    <Button Content="🔍 Process with OCR" 
                            Margin="0,20,0,0" 
                            Padding="15,10" 
                            Background="#10B981" 
                            Foreground="White"
                            BorderThickness="0"
                            HorizontalAlignment="Left"
                            Cursor="Hand"
                            AutomationProperties.Name="Process document with OCR"/>

                    <TextBlock Name="OcrResult" 
                               Text="" 
                               Margin="0,15,0,0" 
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </TabItem>

            <!-- Settings Tab -->
            <TabItem Header="Settings">
                <StackPanel Margin="20">
                    <TextBlock Text="Agent Configuration" 
                               FontSize="18" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Hospital Name:" Margin="0,0,10,10" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="Springfield Medical Center" Margin="0,0,0,10" Padding="8"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Department:" Margin="0,0,10,10" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="Registration" Margin="0,0,0,10" Padding="8"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="API Endpoint:" Margin="0,0,10,10" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="https://localhost:5003/api" Margin="0,0,0,10" Padding="8"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Agent Version:" Margin="0,0,10,10" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="1.0.0" Margin="0,0,0,10" VerticalAlignment="Center"/>
                    </Grid>

                    <Button Content="Save Settings" 
                            Margin="0,20,0,0" 
                            Padding="20,10" 
                            Background="#2563EB" 
                            Foreground="White"
                            BorderThickness="0"
                            HorizontalAlignment="Left"
                            Cursor="Hand"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="10">
            <Grid>
                <TextBlock Text="Status: Connected" 
                           Foreground="Green" 
                           FontSize="12"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Last Heartbeat: Just now" 
                           HorizontalAlignment="Right" 
                           FontSize="12"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>

